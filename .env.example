# 必填：通义千问 / DashScope API Key。
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DashScope OpenAI-compatible API。
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSIONS=1024
QWEN_CHAT_MODEL=qwen-plus
QWEN_RERANK_MODEL=qwen3-rerank
QWEN_RERANK_API_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
MODEL_REQUEST_TIMEOUT_SECONDS=60

# 本地直接运行 FastAPI 时使用 127.0.0.1。
# Docker Compose 中会覆盖成 http://qdrant:6333。
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION_NAME=rag_chunks

# RAG 默认参数。
RAG_DEFAULT_TOP_K=3
RAG_DEFAULT_MIN_SCORE=0.55
RAG_DEFAULT_CANDIDATE_K=6
RAG_DEFAULT_RERANK_TOP_K=3
RAG_DEFAULT_RERANK_MIN_SCORE=0.75
RAG_DEFAULT_FALLBACK_MIN_SCORE=0.55
RAG_SLOW_RERANK_THRESHOLD=3.0

# 日志级别：DEBUG / INFO / WARNING / ERROR。
LOG_LEVEL=INFO

# Spring Boot MySQL 配置。
# 本地 Docker Compose 启动 MySQL 后，Spring Boot 默认连接下面这个数据库。
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=rag_knowledge_base
MYSQL_URL=jdbc:mysql://127.0.0.1:3307/rag_knowledge_base?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
MYSQL_USER=rag_user
MYSQL_PASSWORD=rag_password
